COREF_MODEL=lingmess          # lingmess | fcoref | cascade
COREF_DEVICE=cpu              # cpu or cuda:0
COREF_RESOLVE_MODE=anaphora   # anaphora or pronouns_only
COREF_PRELOAD=true            # load the model at startup

# Cascade mode (COREF_MODEL=cascade) runs LingMess first, then s2e-coref fills
# the mentions LingMess missed. It needs the s2e checkpoint mounted here:
S2E_MODEL_PATH=               # e.g. /models/s2e  (dir with pytorch_model.bin + config.json)
S2E_TOKENIZER=allenai/longformer-large-4096
